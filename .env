VITE_SP_HOST=portal.army.idf
VITE_SP_SITE_CODE=schedule
VITE_SP_SITE_DB_FOLDER=siteDB
VITE_SP_USERS_DB_FOLDER=/sites/schedule/siteUsersDb
VITE_SP_BOOTSTRAP_LIBRARY=SiteAssets
VITE_SP_BOOTSTRAP_FOLDER=sitebuilder-bootstrap
VITE_SP_SITE_ASSETS_FOLDER=siteAssets
VITE_SP_IMAGES_FOLDER=images
VITE_SP_WIDGETS_DB_TARGET=users

# Optional overrides (normally auto-derived)
# VITE_SP_SITE_API_ROOT=/sites/schedule
# VITE_SITE_BASE_URL=https://portal.army.idf/sites/schedule/siteDB/dist

# Logging (מרוכז)
VITE_SP_VERBOSE_LOG=true
VITE_SP_PERMISSIONS_SETUP_LOGS=true
VITE_SP_ENABLE_OWNERS_MANAGEMENT_LOGS=true
VITE_SP_LOG_FETCH_ADMINS=true
VITE_SP_LOG_FETCH_ADMINS_VERBOSE=true
VITE_ALPHA_AI_DEBUG=true
VITE_SP_BOOTSTRAP_SETUP_LOGS=true

# deploymen
VITE_AUTO_DEPLOY=true
VITE_AUTO_DEPLOY_STRICT=true

# Alpha AI proxy integration (newAlphaAIBackend)
VITE_ALPHA_AI_ENABLED=true
VITE_UI_SHOW_AI_UI=true
VITE_UI_SHOW_QUICK_DESIGN_COMPOSER=true
VITE_ALPHA_AI_API_BASE=https://alphaai.idf/api
VITE_ALPHA_AI_MODEL=jack-auto
VITE_ALPHA_AI_FALLBACK_MODELS=jack-auto,claude-3-haiku-20240307,gemini-1.5-pro
VITE_ALPHA_AI_STREAM_MODEL=jack-auto
VITE_ALPHA_AI_STREAM_ENDPOINT=/chat/jack-auto
VITE_ALPHA_AI_TIMEOUT_MS=30000
VITE_ALPHA_AI_STREAM_TIMEOUT_MS=120000
VITE_ALPHA_AI_API_TOKEN=sk-ab40...
