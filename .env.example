VITE_SP_BOOTSTRAP_LIBRARY=SiteAssets
VITE_SP_BOOTSTRAP_FOLDER=sitebuilder-bootstrap
VITE_SP_SITE_ASSETS_FOLDER=siteAssets
VITE_SP_IMAGES_FOLDER=images
VITE_SP_WIDGETS_DB_TARGET=users

# Optional overrides, normally auto-derived.
VITE_SP_SITE_API_ROOT=/sites/schedule
VITE_SITE_BASE_URL=https://portal.army.idf/sites/schedule/siteDB/dist

# Logging.
VITE_SP_VERBOSE_LOG=false
VITE_SP_APP_LOGS=false
VITE_SP_APP_WARN_ERROR_LOGS=false
VITE_SP_PERMISSIONS_SETUP_LOGS=false
VITE_SP_LIBRARY_PROVISIONING_LOGS=false
VITE_SP_ADMIN_MANAGEMENT_LOGS=false
VITE_SP_ENABLE_OWNERS_MANAGEMENT_LOGS=false
VITE_SP_LOG_FETCH_ADMINS=false
VITE_SP_LOG_FETCH_ADMINS_VERBOSE=false
VITE_SP_BOOTSTRAP_SETUP_LOGS=false
VITE_ALPHA_AI_DEBUG=false

# Optional Alpha Team footer/admin banner data.
VITE_APP_VERSION=0.2.3
VITE_ALPHA_TEAM_NAME_HE=צוות אלפא
VITE_ALPHA_TEAM_NAME_EN=Alpha Team
VITE_ALPHA_TEAM_LOGO_PATH=/images/alphalogo1.png
VITE_ALPHA_TEAM_EMAIL=
VITE_ALPHA_TEAM_SITE_URL=

# Local/deploy automation.
VITE_AUTO_DEPLOY=false
VITE_AUTO_DEPLOY_STRICT=false

# Alpha AI proxy integration.
VITE_ALPHA_AI_ENABLED=false
VITE_UI_SHOW_AI_UI=false
VITE_UI_SHOW_QUICK_DESIGN_COMPOSER=true
VITE_ALPHA_AI_API_BASE=http://localhost:3000/api
VITE_ALPHA_AI_MODEL=gpt-4o
VITE_ALPHA_AI_FALLBACK_MODELS=claude-3-haiku-20240307,gemini-1.5-pro
VITE_ALPHA_AI_STREAM_MODEL=any
VITE_ALPHA_AI_STREAM_ENDPOINT=/ai/stream
VITE_ALPHA_AI_TIMEOUT_MS=30000
VITE_ALPHA_AI_STREAM_TIMEOUT_MS=120000
VITE_ALPHA_AI_API_TOKEN=
