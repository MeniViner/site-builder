              {/* Outer Glass Container */}
              <div
                className="absolute inset-0 bg-white/10 backdrop-blur-xl transition-colors border-l border-t border-white/20"
                style={{ clipPath: 'polygon(30px 0, 100% 0, 100% calc(100% - 30px), calc(100% - 30px) 100%, 0 100%, 0 30px)' }}
              />
              <div
                className="absolute inset-[1px] bg-gradient-to-br from-[#12141a]/80 to-[#0a0c0f]/95 backdrop-blur-2xl"
                style={{ clipPath: 'polygon(29px 0, 100% 0, 100% calc(100% - 29px), calc(100% - 29px) 100%, 0 100%, 0 29px)' }}
              >
                {/* Bottom glowing red line */}
                <div className="absolute bottom-0 left-[20%] right-[20%] h-[3px] bg-red-600 shadow-[0_0_20px_4px_rgba(220,38,38,0.8)]" />
