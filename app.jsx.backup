                  <button className="w-8 h-8 flex items-center justify-center border border-gray-700 text-gray-300 hover:bg-red-600 hover:text-white hover:border-transparent transition rounded-sm bg-[#12141a]/50">
                    <ChevronRight size={16} />
                  </button>
                  <button className="w-8 h-8 flex items-center justify-center border border-gray-700 text-gray-300 hover:bg-red-600 hover:text-white hover:border-transparent transition rounded-sm bg-[#12141a]/50">
