                      <div className="w-[70px] bg-[#d32f2f] flex flex-col items-center justify-center border-l border-red-500/30">
                        <span className="text-[22px] font-black text-white leading-[1.1]">06</span>
                        <span className="text-[14px] font-bold text-white/90 leading-[1.1] mt-1">אוק</span>
                      </div>
                      <div className="flex-1 flex flex-col justify-center pr-4 text-right">
                        <div className="font-bold text-[17px] text-white leading-tight drop-shadow-sm truncate">ביקורת כשירות רבעונית</div>
                        <div className="text-[12px] text-red-100 tracking-wider mt-1 opacity-90 truncate">כולל תרגול חרום</div>
                      </div>
                    </div>
                  </div>

                  {/* Row 2 */}
                  <div className="relative h-[76px] group cursor-pointer transition-transform hover:-translate-y-0.5">
                    <div className="absolute inset-0 bg-gray-600/60 group-hover:bg-red-500/60 transition-colors"
                      style={{ clipPath: 'polygon(12px 0, 100% 0, 100% calc(100% - 12px), calc(100% - 12px) 100%, 0 100%, 0 12px)' }} />
                    <div className="absolute inset-[1px] bg-[#16181f]/80 group-hover:bg-[#1a1c24]/95 flex items-stretch backdrop-blur-md transition-colors"
                      style={{ clipPath: 'polygon(11px 0, 100% 0, 100% calc(100% - 11px), calc(100% - 11px) 100%, 0 100%, 0 11px)' }}>
                      <div className="w-[70px] flex flex-col items-center justify-center border-l border-gray-700/50">
