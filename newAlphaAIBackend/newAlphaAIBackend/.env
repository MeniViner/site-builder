# Server Settings
PORT=3000
NODE_ENV=development

# Security
FRONTEND_DOMAIN=*
ALLOW_ALL_ORIGINS=true
DISABLE_AUTH_GUARD=true
TRUST_PROXY=true
API_SECRET_TOKEN=

# API Keys (Comma Separated for KeyManager Rotation)
