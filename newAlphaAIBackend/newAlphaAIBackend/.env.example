# Server Settings
PORT=3000
NODE_ENV=development

# Security
FRONTEND_DOMAIN=http://localhost:5173
ALLOW_ALL_ORIGINS=true
DISABLE_AUTH_GUARD=true
TRUST_PROXY=true
API_SECRET_TOKEN=

# API Keys, comma-separated for key rotation.
OPENAI_API_KEYS=
ANTHROPIC_API_KEYS=
GEMINI_API_KEYS=
FALLBACK_MODELS=gpt-4o,gemini-1.5-pro,claude-3-haiku-20240307

# Timeouts
DEFAULT_TIMEOUT_MS=15000
STREAM_TIMEOUT_MS=45000
